<mxfile host="65bd71144e">
    <diagram id="VS7wYbb9IQ1RzrPIa8iS" name="Page-1">
        <mxGraphModel dx="2337" dy="2526" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="16" value="" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="90" y="-70" width="1190" height="1600" as="geometry"/>
                </mxCell>
                <mxCell id="2" value="CURRENT" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="315" y="10" width="160" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="19" value="&lt;div&gt;ADDITIONALLY Noise example:&lt;/div&gt;[&#39;On 3 November 2022, a spokesman for the Federal Foreign Office (04.11.) issued the following statement on the consultations of the Foreign and Defence Ministers of Germany and Japan:&#39;, &#39;Foreign Minister Baerbock met Japanese Foreign Minister Hayashi in Münster on 3 November 2022 and conducted security policy consultations in 2+2 format together with Defence Minister Lambrecht and Japanese Defence Minister Hamada, both of whom had virtually joined forces.&#39;, &#39;In the spirit of the close and trustful partnership of values between Germany and Japan, ministers discussed current international issues, including the brutal Russian war of aggression against Ukraine, the situation in the Indo-Pacific and the Korean Peninsula, and the role of China.&#39;, &#39;They also exchanged views on bilateral issues such as work on the respective national security strategies and intensified armaments and defence cooperation.&#39;]" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="680" y="1275" width="570" height="185" as="geometry"/>
                </mxCell>
                <mxCell id="24" value="&lt;font style=&quot;font-size: 20px;&quot;&gt;Methodology (Current VS Envisioned)&lt;/font&gt;" style="rounded=0;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="425" y="-70" width="500" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="41" value="STEP 1 MANUAL CODING (340 SEGMENTS)&lt;div&gt;-10 random segments per year per actor&lt;/div&gt;&lt;div&gt;-manually coded across four binary dimensions: realist stance (0/1), diplomatic stance (0/1), EU collective framing (0/1), intensity (0/1/2, later collapsed to binary)&lt;/div&gt;&lt;div&gt;-noise segments identified and labeled&lt;/div&gt;&lt;div&gt;-no inter-rater reliability check done&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
                    <mxGeometry x="110" y="85" width="570" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="43" value="ENVISIONED" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
                    <mxGeometry x="885" y="10" width="160" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="52" value="STEP 1 Expanded manual coding (which could give approx. 466 segments in total)&lt;div&gt;-additional manually coded 205 segments, again the same method: 6 random segments per year per actor&lt;/div&gt;&lt;div&gt;-inter-rater reliability check on subset (Cohen&#39;s Kappa?)&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
                    <mxGeometry x="680" y="85" width="570" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="57" value="STEP 2 Preprocessing&lt;div&gt;-noise segments filtered out (76 removed, leaving 266)&lt;/div&gt;&lt;div&gt;-Separate subset containing only French and German press releases for EU collective framing dimension (decision grounded in theory)&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
                    <mxGeometry x="110" y="255" width="570" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="58" value="STEP 2 Preprocessing&lt;div&gt;-stays largely the same, but i filter out the new noise segments&amp;nbsp;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
                    <mxGeometry x="680" y="255" width="570" height="75" as="geometry"/>
                </mxCell>
                <mxCell id="60" value="STEP 3 Feature Engineering&lt;div&gt;-four keyword lists constructed (or rather finalised, as they were being built during step 1)&lt;/div&gt;&lt;div&gt;-keywords matched against lemmatised text using regex with word boundaries&lt;/div&gt;&lt;div&gt;-raw keyword count divided by segment length, which gives us keyword rates (one rate per dimension per segment)&lt;/div&gt;&lt;div&gt;-single feature per dimension fed to classifier&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
                    <mxGeometry x="110" y="425" width="570" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="61" value="STEP 3 Revised feature engineering (3 substeps)&lt;div&gt;1. Manual keyword weighting&lt;/div&gt;&lt;div&gt;-keyword lists refined to remove context-specific terms (as mentioned in the email)&lt;/div&gt;&lt;div&gt;-manual differential weights assigned: 1=weak/ambiguous, 2=moderate, 3=strong/domain-specific&lt;/div&gt;&lt;div&gt;-done using the corpus knowledge and theoretical knowledge&lt;/div&gt;&lt;div&gt;2. TF-IDF corpus reweighting (data-driven)&lt;/div&gt;&lt;div&gt;-TF-IDF fitted on my full 3020 segment corpus using my keyword vocabulary&lt;/div&gt;&lt;div&gt;-keywords that appear across all press releases downweighted automatically&lt;/div&gt;&lt;div&gt;-rare but distinctive keywords upweighted&lt;/div&gt;&lt;div&gt;final keyword weight = manual theoretical weight * TF-IDF IDF score&lt;/div&gt;&lt;div&gt;3. Interaction features&lt;/div&gt;&lt;div&gt;-pairwise interaction terms between dimension rates added as additional features&lt;/div&gt;&lt;div&gt;-i.e. realist and intensity, or diplomatic and realist, etc.&lt;/div&gt;&lt;div&gt;-inspired by what Celina mentioned during the meeting - Venn Diagram; how the overlap between features may be grounded in theory and also interesting to observe&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
                    <mxGeometry x="680" y="340" width="570" height="235" as="geometry"/>
                </mxCell>
                <mxCell id="63" value="STEP 4 Classification&lt;div&gt;-Separate logistic regression classifier per dimension&lt;/div&gt;&lt;div&gt;-80/20 train/test split, stratified&lt;/div&gt;&lt;div&gt;-5-fold cross-validated grid search over c and max_iter&lt;/div&gt;&lt;div&gt;-class_weight = &#39;balanced&#39; to handle imbalance&lt;/div&gt;&lt;div&gt;-scoring metric: f1_weighted&lt;/div&gt;&lt;div&gt;-EU collective framing trained on France/Germany only (192 segments), EEAS assigned 1 by rule&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
                    <mxGeometry x="110" y="595" width="570" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="64" value="STEP 4 Classification&lt;div&gt;&lt;span style=&quot;color: rgb(63, 63, 63);&quot;&gt;-essentiially more motivated by theory (Celina suggestion, dimensions co occur in meaningful combinations)&lt;/span&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;br&gt;&lt;/font&gt;&lt;div&gt;-Two ideas: either a shallow RandomForest, which is a bit more sophisticated, a lot less interpretable, and likely dimishies the importance of manual+TF-IDF weighting,&amp;nbsp; but at least catches cross-dimensionsal patterns, which could be interesting OR multilabel classification with additional interaction features (such as realist x intense)&lt;/div&gt;&lt;div&gt;-I would still have to work around my peculiar EU collective framing diension (since EEAS assigned 1 as a rule, still). I could handle EU collective framing separately for EEAS but include it in multilabel training for France/Germany&lt;/div&gt;&lt;div&gt;-class_weight = &#39;Balanced&#39; still&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
                    <mxGeometry x="680" y="595" width="570" height="195" as="geometry"/>
                </mxCell>
                <mxCell id="66" value="STEP 5 Validation&lt;div&gt;-validated on full 266 manually coded segments&lt;/div&gt;&lt;div&gt;-metrics reported: accuracy, precision, recall, F1 weighted&lt;/div&gt;&lt;div&gt;-rule-based intensity compared against classifier as baseline&lt;/div&gt;&lt;div&gt;-confusion matrices and false positive/negative analysis conducted iteratively&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
                    <mxGeometry x="110" y="765" width="570" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="67" value="STEP 5 Temporal train/test split&lt;div&gt;-I did a random 80/20 split, but instead I could train based on time (so from my labeled dataset the 80 % could be from segemnts from 2014- 2020 (or wherever woudl be around 80%), and test on segments from 2020-2025 (approximately))&lt;/div&gt;&lt;div&gt;-it woudl be more strict which is good since i am doing a longitudinal study, so it should show me how it performs on a period it didn&#39;t see&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
                    <mxGeometry x="680" y="800" width="570" height="115" as="geometry"/>
                </mxCell>
                <mxCell id="69" value="STEP 6 Refinement&lt;div&gt;-false positives and negatives checked manually&lt;/div&gt;&lt;div&gt;-keyword lists refined&amp;nbsp;&lt;/div&gt;&lt;div&gt;some segments recoded after close reading during diagnosis process&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
                    <mxGeometry x="110" y="935" width="570" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="70" value="STEP 6 Output&lt;div&gt;-binary predictions per dimension per segment&amp;nbsp;&lt;/div&gt;&lt;div&gt;-predicted probabilities retained as continuous rhetorical scores (as mentioend in the email)&lt;/div&gt;&lt;div&gt;-both stored alongside main info&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
                    <mxGeometry x="680" y="935" width="570" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="76" value="STEP 7 Scaling&lt;div&gt;-Trained multilabel/random forest classifier would be applied to all segments&lt;/div&gt;&lt;div&gt;-EEAS rule applied for EU colelctive framing&lt;/div&gt;&lt;div&gt;-50(?) random segments manually verified for face validity&lt;/div&gt;&lt;div&gt;- maybe some sort of check based on events? i.e. I assume relatively high intensity after 2022 Invasion, is it there?&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
                    <mxGeometry x="680" y="1105" width="570" height="150" as="geometry"/>
                </mxCell>
                <mxCell id="80" value="STEP 7 Scaling&lt;div&gt;Performance of the classifier verified on unseen data (36 press releases, 1 per year per actor, different random seed)&lt;/div&gt;&lt;div&gt;-outcome:&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp;&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
                    <mxGeometry x="110" y="1105" width="570" height="355" as="geometry"/>
                </mxCell>
                <mxCell id="81" value="" style="shape=image;verticalLabelPosition=bottom;labelBackgroundColor=default;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/png,;" vertex="1" parent="1">
                    <mxGeometry x="165.75" y="1315.87" width="458.5" height="103.27" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
</mxfile>