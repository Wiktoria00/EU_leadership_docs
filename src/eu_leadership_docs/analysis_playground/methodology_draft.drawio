                <mxCell id="8" value="keyword lists formed on the basis of 340 press releases segments (relevant chunks), 100 per actor, 10 random ones per year. Since intensity can be 1 or 2, seperate keyword lists to account for it." style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
                    <mxGeometry x="330" y="90" width="120" height="310" as="geometry"/>
                </mxCell>
                <mxCell id="9" value="issue distribution&lt;div&gt;(so far: law, diplomacy, firmness (has roots in language used in samples, means rhetoric connected to sanctions), society, franco-german relation, noise )&lt;/div&gt;" style="rounded=0;whiteSpace=wrap;html=1;" vertex="1" parent="1">
